# Supabase project URL (Dashboard > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Service role key (Dashboard > Project Settings > API)
# Keep this key server-side only. Do not expose it in client-side code.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Random long secret used to sign login session cookies.
AUTH_SESSION_SECRET=replace-with-a-long-random-secret
